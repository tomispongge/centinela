# Copia este archivo a .env y completa con las credenciales de tu proyecto Supabase.
# La anon key es pública por diseño, pero se mantiene fuera del código (gitignored)
# y se setea también en Vercel → Project Settings → Environment Variables.
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key
